# Copy this file to .env and fill in your own values

# MongoDB connection string
# Local MongoDB:      mongodb://127.0.0.1:27017/shopease
# MongoDB Atlas:       mongodb+srv://<user>:<password>@<cluster>.mongodb.net/shopease
MONGODB_URI=mongodb://127.0.0.1:27017/shopease

# Port the Express server listens on
PORT=5000

# Long random string used to sign session cookies
# (generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=change-this-to-a-long-random-string

# The URL your frontend is served from (for CORS)
CLIENT_ORIGIN=http://127.0.0.1:5500
